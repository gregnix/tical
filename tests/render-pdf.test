package require tcltest 2
namespace import tcltest::*

lappend auto_path [file normalize [file dirname [info script]]/..]
package require tical::core
package require tical::util
package require tical::holidays
package require tical::view::month
package require tical::view::week
package require tical::view::day
package require tical::render::pdf

set testDir [file dirname [info script]]
set tmpDir [file join $testDir tmp-pdf]
file mkdir $tmpDir

proc cleanupTest {} {
    variable tmpDir
    if {[file exists $tmpDir]} {
        file delete -force $tmpDir
    }
}

test pdf-1.1 {Create PDF with month grid} -body {
    set spec [tical::view::month::getData -year 2025 -month 10]
    set outfile [file join $tmpDir test-month.pdf]
    set result [tical::render::pdf::create $outfile $spec]
    list [file exists $outfile] [file extension $result]
} -result {1 .pdf}

test pdf-1.2 {Create PDF with week grid} -body {
    set spec [tical::view::week::getData -year 2025 -week 42]
    set outfile [file join $tmpDir test-week.pdf]
    set result [tical::render::pdf::create $outfile $spec]
    list [file exists $outfile] [file extension $result]
} -result {1 .pdf}

test pdf-1.3 {Create PDF with day grid} -body {
    set spec [tical::view::day::getData -date "2025-10-14"]
    set outfile [file join $tmpDir test-day.pdf]
    set result [tical::render::pdf::create $outfile $spec]
    list [file exists $outfile] [file extension $result]
} -result {1 .pdf}

test pdf-1.4 {PDF month with options} -body {
    set spec [tical::view::month::getData -year 2025 -month 10]
    set outfile [file join $tmpDir test-month-opts.pdf]
    set result [tical::render::pdf::create $outfile $spec \
        -fontsize 12 -weekNumbers 0 -showGrid 1]
    file exists $outfile
} -result {1}

test pdf-1.5 {PDF landscape orientation} -body {
    set spec [tical::view::month::getData -year 2025 -month 10]
    set outfile [file join $tmpDir test-landscape.pdf]
    set result [tical::render::pdf::create $outfile $spec \
        -orientation landscape]
    file exists $outfile
} -result {1}

test pdf-1.6 {PDF letter paper size} -body {
    set spec [tical::view::month::getData -year 2025 -month 10]
    set outfile [file join $tmpDir test-letter.pdf]
    set result [tical::render::pdf::create $outfile $spec \
        -paper letter]
    file exists $outfile
} -result {1}

test pdf-1.7 {PDF custom colors} -body {
    set spec [tical::view::month::getData -year 2025 -month 10]
    set outfile [file join $tmpDir test-colors.pdf]
    set result [tical::render::pdf::create $outfile $spec \
        -colorToday "#FFCCCC" -colorWeekend "#CCFFCC"]
    file exists $outfile
} -result {1}

test pdf-1.8 {PDF with today marker} -body {
    tical::config::set today "2025-10-14"
    set spec [tical::view::month::getData -year 2025 -month 10]
    set outfile [file join $tmpDir test-today.pdf]
    set result [tical::render::pdf::create $outfile $spec]
    file exists $outfile
} -result {1}

test pdf-1.9 {PDF with holidays} -body {
    set spec [tical::view::month::getData -year 2025 -month 10 -holidays {de}]
    set outfile [file join $tmpDir test-holidays.pdf]
    set result [tical::render::pdf::create $outfile $spec]
    file exists $outfile
} -result {1}

test pdf-1.10 {PDF invalid ViewSpec type} -body {
    set spec [dict create type "invalid-type"]
    set outfile [file join $tmpDir test-invalid.pdf]
    tical::render::pdf::create $outfile $spec
} -returnCodes error -match glob -result {Unknown ViewSpec type: invalid-type}

test pdf-1.11 {PDF month without week numbers} -body {
    set spec [tical::view::month::getData -year 2025 -month 10]
    set outfile [file join $tmpDir test-no-weeknums.pdf]
    set result [tical::render::pdf::create $outfile $spec -weekNumbers 0]
    file exists $outfile
} -result {1}

test pdf-1.12 {PDF month without grid lines} -body {
    set spec [tical::view::month::getData -year 2025 -month 10]
    set outfile [file join $tmpDir test-no-grid.pdf]
    set result [tical::render::pdf::create $outfile $spec -showGrid 0]
    file exists $outfile
} -result {1}

cleanupTest

cleanupTests

